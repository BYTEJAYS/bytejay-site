# Jerry's brain — free API key from https://console.groq.com/keys.
# Without it, /jerry still renders but Jerry replies that his brain
# isn't plugged in yet. Server-side only, never exposed to visitors.
GROQ_API_KEY=

# Optional override for where the Jerry icon sends visitors.
# Defaults to the built-in /jerry chat page; set this only if the
# full PRL app gets its own deployment later.
NEXT_PUBLIC_PRL_URL=
